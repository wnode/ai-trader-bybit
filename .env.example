# =========================================
# AI TRADER BOT — LLM-Powered Trading
# =========================================

# =========================================
# BYBIT
# =========================================
BYBIT_API_KEY=your_key_here
BYBIT_API_SECRET=your_secret_here
USE_TESTNET=true
DRY_RUN=true

# =========================================
# TRADING
# =========================================
SYMBOL=BTCUSDT
TIMEFRAME=15
CHECK_INTERVAL=300
LEVERAGE=25
# Risco por trade como fracao do capital (0.0001 = 0.01% para testes, max 0.1 = 10%)
RISK_PER_TRADE=0.0001
# Candles para enviar a LLM (96 = 24h de 15min)
KLINES_TO_SEND=96
# Candles diarios para contexto macro
DAILY_KLINES=30

# =========================================
# INDICADORES TECNICOS
# =========================================
RSI_PERIOD=14
EMA_FAST=9
EMA_MID=21
EMA_SLOW=50
BB_PERIOD=20
BB_STD=2.0
ADX_PERIOD=14
ATR_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
VOL_AVG_PERIOD=20

# =========================================
# REGRAS DE TRADING
# =========================================
# SL minimo e maximo (% do preco de entrada)
SL_MIN_PCT=0.3
SL_MAX_PCT=1.0
# Risk/reward minimo (1.0 = 1:1)
MIN_RR_RATIO=1.0
# Confianca minima da LLM para operar (0.0 a 1.0)
MIN_CONFIDENCE=0.8
# ADX abaixo desse valor = mercado lateral (evitar trades)
ADX_RANGING_THRESHOLD=15

# =========================================
# LLM PROVIDER
# =========================================
# Provider: anthropic, google, openai, xai
LLM_PROVIDER=google

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-2.5-flash

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI GPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini

# xAI Grok (https://console.x.ai)
XAI_API_KEY=your_xai_key
XAI_MODEL=grok-3-mini
# Modelo usado quando XAI_SEARCH=true (precisa ser familia grok-4)
XAI_SEARCH_MODEL=grok-4-1-fast-non-reasoning
# Habilitar x_search + web_search (busca noticias/sentimento em tempo real no X e web)
XAI_SEARCH=false
# Cachear resultado do search por N iteracoes (6 = ~30min com CHECK_INTERVAL=300)
XAI_SEARCH_CACHE_ITERATIONS=6
# Monitor de sentimento durante sleep: checa a cada N segundos (0=desligado)
# Se detectar mudanca brusca (urgencia sobe 3+ pontos ou >= 8), forca analise imediata
SENTIMENT_MONITOR_INTERVAL=120

# =========================================
# SENTIMENTO DE MERCADO
# =========================================
# Fear & Greed Index (alternative.me) — funciona com qualquer provider
USE_SENTIMENT=false
# Cache em minutos (API atualiza 1x/dia)
FNG_CACHE_MINUTES=60
